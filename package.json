{
  "name": "mytheme",
  "version": "1.0.0",
  "scripts": {
    "css": "sass scss/main.scss assets/dist/main.css",
    "css:watch": "sass --watch scss:assets/dist",

    "js": "esbuild assets/js/main.js --bundle --outfile=assets/dist/main.js",
    "js:watch": "esbuild assets/js/main.js --bundle --watch --outfile=assets/dist/main.js",

    "dev": "npm run css:watch & npm run js:watch",
    "build": "npm run css && npm run js"
  },
  "devDependencies": {
    "sass": "^1.69.0",
    "esbuild": "^0.20.0"
  }
}